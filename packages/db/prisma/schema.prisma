generator client {
  provider = "prisma-client-js"
  // Hoisted node_modules is not part of Turbo cache; keep the client inside this
  // package so `^build` restores a usable PrismaClient on cache hits.
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  createdAt    DateTime     @default(now()) @map("created_at")
  orders       Order[]
  tradingBots  TradingBot[]

  @@map("users")
}

enum TradingBotStatus {
  STOPPED
  STARTING
  RUNNING
  ERROR
}

model TradingBot {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  status      TradingBotStatus  @default(STOPPED)
  config      Json
  processPid  Int?              @map("process_pid")
  lastTickAt  DateTime?         @map("last_tick_at")
  lastOutput  Json?             @map("last_output")
  lastError   String?           @map("last_error")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  marketTrail TradingBotCandle[]
  paperTrail  TradingBotPaperTrade[]

  @@index([userId])
  @@index([status])
  @@map("trading_bots")
}

model TradingBotCandle {
  id        String     @id @default(cuid())
  botId     String     @map("bot_id")
  bot       TradingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  timestamp BigInt
  open      Decimal    @db.Decimal(28, 12)
  high      Decimal    @db.Decimal(28, 12)
  low       Decimal    @db.Decimal(28, 12)
  close     Decimal    @db.Decimal(28, 12)
  volume    Decimal    @db.Decimal(28, 12)
  createdAt DateTime   @default(now()) @map("created_at")

  @@unique([botId, timestamp])
  @@index([botId, timestamp(sort: Desc)])
  @@map("trading_bot_candles")
}

model TradingBotPaperTrade {
  id        String     @id @default(cuid())
  botId     String     @map("bot_id")
  bot       TradingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  kind      String
  timestamp BigInt
  price     Decimal    @db.Decimal(28, 12)
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([botId, timestamp(sort: Desc)])
  @@map("trading_bot_paper_trades")
}

model Order {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol          String
  side            String
  type            String
  quantity        Decimal  @db.Decimal(28, 12)
  limitPrice      Decimal? @map("limit_price") @db.Decimal(28, 12)
  status          String
  clientOrderId   String?  @map("client_order_id")
  exchangeOrderId String?  @map("exchange_order_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  trades          Trade[]

  @@index([userId])
  @@index([createdAt])
  @@map("orders")
}

model Trade {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  symbol     String
  side       String
  quantity   Decimal  @db.Decimal(28, 12)
  price      Decimal  @db.Decimal(28, 12)
  fee        Decimal? @db.Decimal(28, 12)
  executedAt DateTime @default(now()) @map("executed_at")

  @@index([orderId])
  @@index([executedAt])
  @@map("trades")
}
