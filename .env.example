# Copy to `.env` at the repo root and/or `apps/api/.env` (or export vars) before running the API.
# See README.md for full setup.

# Postgres — Prisma schema + API persistence (orders, trades, users).
# Default matches infra/docker/docker-compose.yml (user/password/db: shredder).
DATABASE_URL="postgresql://shredder:shredder@localhost:5432/shredder?schema=public"

# Redis — BullMQ connection for async jobs (e.g. order-processing).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT — signing secret and token lifetime. Set JWT_SECRET in any shared environment.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# HTTP
PORT=3001

# Binance Spot — `apps/api` reads these via ConfigService and builds `BinanceAdapter` when key + secret are set
# (portfolio balances, order processor). `@shredder/exchanges` resolves the REST host from env when `baseUrl` is omitted.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# testnet | mainnet: default is Spot testnet. Use true / 1 / yes for mainnet. Ignored if BINANCE_BASE_URL is set.
BINANCE_USE_MAINNET=false
# Optional full Spot REST base URL (overrides BINANCE_USE_MAINNET). Examples: https://api.binance.com | https://testnet.binance.vision
BINANCE_BASE_URL=

# Dashboard (Next.js) — browser calls to the Nest API; default matches local API dev port.
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS — comma-separated browser origins. If unset or empty, all origins are allowed (dev only).
FRONTEND_URL=http://localhost:3000

# Market data — worker tick candles (`@shredder/data`). Use `coingecko` for live charts; omit / `demo` for synthetic demo bars.
# CoinGecko free tier: keep MARKET_DATA_MAX_REQUESTS_PER_MINUTE conservative (see https://docs.coingecko.com/).
MARKET_DATA_PROVIDER=demo
# MARKET_DATA_PROVIDER=coingecko
# Optional Pro/Demo API key (header x-cg-pro-api-key). Free public API can leave empty.
MARKET_DATA_COINGECKO_API_KEY=
# Override REST root (default https://api.coingecko.com/api/v3). Pro: https://pro-api.coingecko.com/api/v3
MARKET_DATA_COINGECKO_BASE_URL=
MARKET_DATA_COINGECKO_VS_CURRENCY=usd
# Sliding window + minimum spacing between HTTP calls (protects shared limits across restarts if only one worker).
MARKET_DATA_MAX_REQUESTS_PER_MINUTE=25
MARKET_DATA_MIN_REQUEST_INTERVAL_MS=1500
# Cap history span passed as `days` to market_chart (1–365 typical).
MARKET_DATA_COINGECKO_MAX_CHART_DAYS=365
# Optional JSON map: {"MYTOKENUSDT":"my-token-id"} merged with built-in BTC/ETH/SOL ids.
MARKET_DATA_COINGECKO_SYMBOL_MAP=

# Worker — when MARKET_DATA_PROVIDER is set to coingecko, these select the candle window.
WORKER_CANDLE_INTERVAL=1h
WORKER_CANDLE_LIMIT=50
# Per tick: log each strategy signal JSON (1 / true / yes).
# WORKER_LOG_STRATEGIES=1
# Per tick: call Market Analyst suggest tool (needs OPENAI_API_KEY); runs once per WORKER_TICK_MS.
# WORKER_AI_ANALYST=1

# OpenAI — required for POST /ai/suggest when using the LLM orchestration path.
OPENAI_API_KEY=

# Optional — models for @shredder/ai suggest agents (defaults shown).
OPENAI_SUGGEST_MODEL=gpt-4o-mini
OPENAI_ORCHESTRATION_MODEL=gpt-4o-mini
